# Server
PORT=3333
POLL_SECONDS=60
STATE_FILE=./data/irating-state.json

# Optional: lock down write/reset endpoints in production.
# OBS_TOKEN=change-me

# iRacing OAuth.
# Recommended if you already have an access token:
# IRACING_AUTH_MODE=token
# IRACING_ACCESS_TOKEN=
# IRACING_REFRESH_TOKEN=
# IRACING_CLIENT_ID=
# IRACING_CLIENT_SECRET=

# Password-limited grant, if your iRacing API client supports it:
# Also accepts pw-limited.
IRACING_AUTH_MODE=password_limited
IRACING_CLIENT_ID=
IRACING_CLIENT_SECRET=
IRACING_USERNAME=
IRACING_PASSWORD=

# Optional: prefer one license in the overlay by default.
# Common values: oval, sports_car, formula_car, dirt_oval, dirt_road
DEFAULT_CATEGORY=sports_car
